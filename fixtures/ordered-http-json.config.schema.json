{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://moonflow.local/contracts/ordered-http-json.v2.schema.json",
  "title": "MoonFlow ordered HTTP JSON transport configuration",
  "type": "object",
  "required": ["contract_version", "transfer_id", "source_url", "expected_source_digest", "max_response_bytes", "max_attempts", "retry_delay_ms", "steps"],
  "properties": {
    "contract_version": {"const": "moonflow.ordered_http_json.v2"},
    "transfer_id": {"type": "string", "minLength": 1},
    "source_url": {"type": "string", "pattern": "^https?://[^@?#]+$"},
    "expected_source_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "max_response_bytes": {"type": "integer", "minimum": 1, "maximum": 16777216},
    "max_attempts": {"type": "integer", "minimum": 1, "maximum": 10},
    "retry_delay_ms": {"type": "integer", "minimum": 0, "maximum": 60000},
    "steps": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": {
        "type": "object",
        "required": ["field", "destination_url"],
        "properties": {
          "field": {"type": "string", "minLength": 1},
          "destination_url": {"type": "string", "pattern": "^https?://[^@?#]+$"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
