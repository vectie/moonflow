// Errors
pub(all) suberror OrchestrationError {
  UnsupportedVersion(field~ : String, version~ : String)
  MalformedInput(field~ : String)
  IdentityMismatch(field~ : String)
  WorkflowMismatch(field~ : String)
  PolicyMismatch(field~ : String)
  GovernanceMismatch(field~ : String)
  AuthorityExpired(expires_at~ : Int64, observed_at~ : Int64)
  EffectProofMismatch(field~ : String)
  OrderingViolation(field~ : String)
  RevisionMismatch(expected~ : Int64, actual~ : Int64)
  DigestMismatch(field~ : String)
  EvidenceMismatch(field~ : String)
  ClockRegression(previous~ : Int64, incoming~ : Int64)
  ArithmeticOverflow(field~ : String)
  ScheduleStateViolation(field~ : String)
  RetryBoundViolation(field~ : String)
  RetryClassificationViolation(field~ : String)
  RetryIdentityReuse(field~ : String)
  LeaseOwnerViolation(field~ : String)
  LeaseEpochViolation(expected_greater_than~ : Int64, actual~ : Int64)
  FencingViolation(expected_greater_than~ : Int64, actual~ : Int64)
  TtlViolation(field~ : String)
  IdempotencyConflict(key~ : String)
  CancellationPrecedenceViolation(field~ : String)
  ReplayBindingViolation(field~ : String)
  RecoveryViolation(field~ : String)
} derive(Eq, @debug.Debug)

